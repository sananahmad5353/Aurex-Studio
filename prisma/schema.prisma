generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  twoFactorEnabled   Boolean  @default(false)
  twoFactorSecret    String   @default("")
  lastLoginAt        DateTime?
  lastLoginIp        String   @default("")
  failedLoginAttempts Int     @default(0)
  lockedUntil        DateTime?
  role               String   @default("admin")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  imageUrl  String
  ctaText   String   @default("Get Started")
  ctaLink   String   @default("#contact")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String   @default("TrendingUp")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id         String   @id @default(cuid())
  name       String
  role       String   @default("")
  company    String   @default("")
  content    String
  rating     Int      @default(5)
  imageUrl   String   @default("")
  order      Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Partner {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  website   String   @default("")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  subject   String   @default("")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Reel {
  id        String   @id @default(cuid())
  platform  String   @default("instagram")
  reelUrl   String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}